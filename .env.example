# Environment
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=novapanel
DB_USER=novapanel
DB_PASSWORD=novapanel_secret
DB_SSL_MODE=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=novapanel-dev-secret-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# API
API_PORT=8080
API_HOST=0.0.0.0

# Automation Service
AUTOMATION_URL=http://localhost:8001

# Frontend
VITE_API_URL=http://localhost:8080/api/v1
VITE_WS_URL=ws://localhost:8080/ws

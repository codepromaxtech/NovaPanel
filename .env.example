# ─── Required ────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 32

DB_NAME=novapanel
DB_USER=novapanel
DB_PASSWORD=change_me_strong_password

REDIS_PASSWORD=change_me_redis_password

# 64-char hex key for encrypting SSH passwords and env vars
ENCRYPTION_KEY=change_me_64_char_hex_key_here_0000000000000000000000000000000000

# JWT signing key
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# ─── Panel URL ───────────────────────────────────────────────
PANEL_URL=http://your-server-ip:8080
PANEL_PORT=8080

# ─── Host Server SSH (required for File Manager, DB, Services) ───────────────
# The Linux user NovaPanel SSHs into the host server as.
# Use your actual OS username (whoami). Must have SSH enabled on port 22.
SSH_USER=your_linux_username
SSH_PASSWORD=your_ssh_password
HOST_USER=your_linux_username
# Leave SSH_PASSWORD blank if using key-based auth (key auto-read from ~/.ssh)

# ─── SMTP (for password reset + alert emails) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=NovaPanel <you@example.com>

# ─── Stripe billing (optional) ───────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Development only ────────────────────────────────────────
ENV=production

# Frontend dev server (only needed for local dev, not Docker Hub install)
VITE_API_URL=http://localhost:8080/api/v1
VITE_WS_URL=ws://localhost:8080/ws
